{
  "name": "academic-homepage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "npm run content:check",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run content:check",
    "build": "vite build",
    "lint": "eslint .",
    "content:check": "node scripts/check-content.js",
    "check": "npm run lint && npm run content:check && node --check src/app.js && node --check src/content.js && node --check scripts/check-content.js && node --check vite.config.js"
  },
  "dependencies": {
    "@fontsource/libertinus-sans": "^5.2.1",
    "@fontsource/libertinus-serif": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "globals": "^16.3.0",
    "vite": "^7.0.4"
  }
}
